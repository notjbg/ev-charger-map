{
  "name": "ev-charger-map",
  "version": "1.0.0",
  "description": "Interactive map of public DC fast charging stations for medium and heavy-duty electric vehicles across the United States.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/notjbg/ev-charger-map"
  },
  "keywords": ["ev", "charger", "fleet", "map", "nrel", "afdc"],
  "author": "Jonah Berg",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  }
}
